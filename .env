# Threat Triage Agent — API Key Configuration
# Copy this file to .env and fill in your keys.
#
# ABUSECH_API_KEY is strongly recommended — it enables URLhaus, MalwareBazaar,
# and ThreatFox, which are the primary detection sources for the tool.
# Free signup (no credit card, no limits on lookups):
#   https://bazaar.abuse.ch/api/

# abuse.ch unified API key (covers URLhaus, MalwareBazaar, ThreatFox)
ABUSECH_API_KEY=9c8a004954e8e278833ecc90a7198e53f147c7dac97b1895

# VirusTotal free API key — multi-engine AV scanning for hashes, IP/domain reputation
# Sign up at: https://www.virustotal.com/gui/join-us
VT_API_KEY=691bc562e06d8fda12e73695ca5bd3925f220ba719b0858945d83fc6e8ea3897

# AbuseIPDB free API key — IP abuse confidence score, report history, Tor detection
# Sign up at: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=458b12b079f43476beb90600293ad5efea3c943de18730173881927f56c3be52343988c6b5c36778
